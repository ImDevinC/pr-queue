{
  "display_information": {
    "name": "PR Queue Bot",
    "description": "Monitors Slack messages for GitHub PR links and adds them to the PR queue",
    "background_color": "#000000"
  },
  "features": {
    "bot_user": {
      "display_name": "PR Queue",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "groups:history",
        "chat:write",
        "reactions:write",
        "channels:read",
        "groups:read",
        "mpim:history",
        "im:history"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://hkdk.events/1davhusggg6qo2/slack/events",
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false,
    "is_mcp_enabled": false
  }
}
